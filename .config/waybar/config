{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 0,
    "reload_style_on_change": true,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["mpris"],
    "modules-right": [
        "tray",
        "pulseaudio",
        "backlight",
        "network",
        "bluetooth",
        "cpu",
        "memory",
        "battery",
        "clock",
        "custom/notifications"
    ],

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}"
    },

    "sway/mode": {
        "format": "{}"
    },

    "mpris": {
        "format": "{status_icon}  {artist} — {title}",
        "status-icons": {
            "playing": "󰐊",
            "paused": "󰏤",
            "stopped": "󰓛"
        },
        "max-length": 60,
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next",
        "tooltip-format": "{player}  ·  {album}"
    },

    "tray": {
        "icon-size": 15,
        "spacing": 10
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "󰝟  mute",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "swaync-client -t",
        "tooltip-format": "{desc}"
    },

    "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "tooltip": false
    },

    "network": {
        "format-wifi": "󰤨  {essid}",
        "format-ethernet": "󰈀  wired",
        "format-disconnected": "󰤭  offline",
        "tooltip-format-wifi": "{essid}  ·  {signalStrength}%  ·  {frequency} GHz\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}  ·  {ipaddr}",
        "tooltip-format-disconnected": "no connection",
        "on-click": "alacritty --class float-tui -e nmtui",
        "max-length": 24
    },

    "bluetooth": {
        "format": "󰂯",
        "format-connected": "󰂱 {num_connections}",
        "format-disabled": "󰂲",
        "tooltip-format": "{controller_alias}  ·  {status}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "blueman-manager"
    },

    "cpu": {
        "interval": 2,
        "format": "󰻠  {usage}%",
        "states": {
            "warning": 70,
            "critical": 90
        },
        "on-click": "~/.bin/sysdash.sh"
    },

    "memory": {
        "interval": 2,
        "format": "󰍛  {used:0.1f}G",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G  ·  swap {swapUsed:0.1f}G",
        "on-click": "~/.bin/sysdash.sh"
    },

    "battery": {
        "interval": 10,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "󱐋 {capacity}%",
        "format-icons": ["󰁺", "󰁼", "󰁾", "󰂀", "󰁹"],
        "tooltip-format": "{timeTo}  ·  {power:0.1f} W"
    },

    "clock": {
        "format": "{:%H:%M  ·  %d.%m}",
        "format-alt": "{:%A, %d %B %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<b>{}</b>",
                "weekdays": "<span color='#808080'>{}</span>",
                "today": "<b><u>{}</u></b>"
            }
        }
    },

    "custom/notifications": {
        "format": "{icon}",
        "format-icons": {
            "notification": "󱅫",
            "none": "󰂚",
            "dnd-notification": "󰂛",
            "dnd-none": "󰂛",
            "inhibited-notification": "󱅫",
            "inhibited-none": "󰂚",
            "dnd-inhibited-notification": "󰂛",
            "dnd-inhibited-none": "󰂛"
        },
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
        "tooltip": false
    }
}
